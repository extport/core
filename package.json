{
  "name": "extport-core",
  "version": "1.0.0",
  "description": "Control plane scripts for the extport GitHub org",
  "private": true,
  "type": "module",
  "scripts": {
    "check-upstreams": "node scripts/check-upstreams.js",
    "health-check": "node scripts/health-check.js",
    "dispatch-syncs": "node scripts/dispatch-syncs.js",
    "sync-template-github": "node scripts/sync-template-github.js",
    "test": "c8 --check-coverage --lines 80 --branches 80 --functions 80 node --experimental-test-module-mocks --test 'tests/**/*.test.js'",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^24.13.2",
    "c8": "^11.0.0"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
